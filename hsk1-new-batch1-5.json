        "title": "3. Hậu tố số nhiều 们",
        "desc": "Thêm 们 (men) vào sau đại từ nhân xưng hoặc danh từ chỉ người để biểu thị số nhiều.",
        "formula": [{"text": "Đại từ nhân xưng + 们", "classes": "border-purple-200 bg-purple-50 text-purple-700"}],
        "practiceList": [
          {"correct": "你们好！", "pinyin": "Nǐmen hǎo!", "meaning": "Chào các bạn!"},
          {"correct": "老师们好！", "pinyin": "Lǎoshīmen hǎo!", "meaning": "Chào các thầy cô giáo!"}
