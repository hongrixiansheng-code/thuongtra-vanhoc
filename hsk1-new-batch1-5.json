        "practiceList": [
          {"correct": "我是学生。", "pinyin": "Wǒ shì xuéshēng.", "meaning": "Tôi là học sinh."},
          {"correct": "他们不是老师。", "pinyin": "Tāmen bú shì lǎoshī.", "meaning": "Họ không phải là giáo viên."}
        ]
      },
      {
        "title": "2. Câu hỏi với trợ từ 吗",
        "desc": "Thêm trợ từ nghi vấn 吗 (ma) vào cuối câu trần thuật để biến nó thành câu hỏi Có/Không.",
        "formula": [{"text": "Câu trần thuật + 吗?", "classes": "border-green-200 bg-green-50 text-green-700"}],
        "practiceList": [
          {"correct": "你是学生吗？", "pinyin": "Nǐ shì xuéshēng ma?", "meaning": "Bạn là học sinh phải không?"},
          {"correct": "我们是朋友吗？", "pinyin": "Wǒmen shì péngyǒu ma?", "meaning": "Chúng ta là bạn bè phải không?"}
        ]
      },
