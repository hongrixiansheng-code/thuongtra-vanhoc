      {
        "title": "Hội thoại: Lịch trình mỗi ngày",
        "lines": [
          {
            "speaker": "A",
            "zh": "大卫，你每天几点起床？",
            "py": "Dàwèi, nǐ měitiān jǐ diǎn qǐchuáng?",
            "vi": "David, bạn thức dậy lúc mấy giờ mỗi ngày?"
          },
          {
            "speaker": "B",
            "zh": "我每天六点半起床。",
            "py": "Wǒ měitiān liù diǎn bàn qǐchuáng.",
            "vi": "Tôi thức dậy lúc 6 rưỡi mỗi ngày."
          },
          {
            "speaker": "A",
            "zh": "你先吃早饭还是先洗澡？",
            "py": "Nǐ xiān chī zǎofàn háishì xiān xǐzǎo?",
            "vi": "Bạn ăn sáng trước hay tắm trước?"
          },
          {
            "speaker": "B",
            "zh": "我先洗澡，然后吃早饭。八点去上班。",
            "py": "Wǒ xiān xǐzǎo, ránhòu chī zǎofàn. Bā diǎn qù shàngbān.",
            "vi": "Tôi tắm trước, sau đó ăn sáng. 8 giờ đi làm."
          },
          {
            "speaker": "A",
            "zh": "你迟到过吗？",
            "py": "Nǐ chídào guo ma?",
            "vi": "Bạn đã từng đến muộn chưa?"
          },
          {
            "speaker": "B",
            "zh": "没有，我从来不迟到。",
            "py": "Méiyǒu, wǒ cónglái bù chídào.",
            "vi": "Chưa, tôi không bao giờ đến muộn."
          }
        ]
      }
    ]
  },
