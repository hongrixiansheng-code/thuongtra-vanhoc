generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String         @id @default(uuid())
  name                  String?
  email                 String?        @unique
  emailVerified         DateTime?
  image                 String?
  passwordHash          String?
  role                  String         @default("USER") // "USER" | "ADMIN" | "TEACHER"
  subscriptionStatus    String         @default("FREE") // "FREE" | "PREMIUM"
  subscriptionEndDate   DateTime?
  createdAt             DateTime       @default(now())

  isBanned              Boolean        @default(false)
  lastLoginAt           DateTime?
  nameChangedAt         DateTime?      // chuẩn bị cho tính năng tương lai: user tự đổi tên, 14 ngày/lần
  sessionsInvalidatedAt DateTime?      // set = now() khi Force Logout hoặc Ban để buộc phiên JWT hiện tại phải đăng nhập lại

  accounts              Account[]
  sessions              Session[]
  progress              UserProgress[]
  payments              Payment[]
  taughtClasses         Class[]            @relation("TeacherClasses")
  enrollments           ClassEnrollment[]  @relation("StudentEnrollments")
  auditLogsAsAdmin      AdminAuditLog[]    @relation("AuditLogAdmin")
  auditLogsAsTarget     AdminAuditLog[]    @relation("AuditLogTarget")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String?
  adminEmail   String   // snapshot lúc ghi log, đọc được kể cả sau khi admin bị xóa
  targetUserId String?
  targetEmail  String   // snapshot lúc ghi log, đọc được kể cả sau khi target bị xóa
  action       String   // "ROLE_CHANGE" | "SUBSCRIPTION_CHANGE" | "BAN" | "UNBAN" | "DELETE" | "FORCE_LOGOUT" | "NAME_CHANGE" | "EMAIL_CHANGE" | "CREATE"
  detail       Json?    // { before: ..., after: ... }
  createdAt    DateTime @default(now())

  admin        User?    @relation("AuditLogAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subject {
  id        String    @id @default(uuid())
  name      String    // e.g., "Tiếng Anh", "Tiếng Trung"
  code      String    @unique // e.g., "zh", "en", "ja", "math"
  flag      String?   // e.g., "🇨🇳", "🇬🇧", "🇯🇵"
  color     String?   // e.g., "bg-red-500"
  createdAt DateTime  @default(now())

  programs  Program[]
}

model Program {
  id          String    @id @default(uuid())
  subjectId   String
  name        String    // e.g., "HSK 1 - Cấp độ Cơ bản"
  code        String    @unique // e.g., "hsk1", "en-starters", "n3"
  level       Int
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())

  subject   Subject   @relation(fields: [subjectId], references: [id])
  lessons   Lesson[]
  classes   Class[]
}

model Lesson {
  id          String    @id @default(uuid())
  programId   String
  title       String
  theme       String?   // e.g., "CHỦ ĐỀ I: CHÀO HỎI & LÀM QUEN"
  orderIndex  Int
  isPremium   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  program     Program   @relation(fields: [programId], references: [id])
  contents    LessonContent[]
  userProgress UserProgress[]
  assignments  Assignment[]
}

model LessonContent {
  id          String    @id @default(uuid())
  lessonId    String
  contentType String    // "THEORY", "FORMULA", "EXERCISE", "REVIEW"
  content     String
  createdAt   DateTime  @default(now())

  lesson      Lesson    @relation(fields: [lessonId], references: [id])
}

model UserProgress {
  id             String    @id @default(uuid())
  userId         String
  lessonId       String
  completed      Boolean   @default(false)
  score          Int       @default(0)
  completedAt    DateTime?
  lastReviewedAt DateTime  @default(now())
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Payment {
  id                   String    @id @default(uuid())
  userId               String
  amount               Float
  status               String    // "PENDING", "SUCCESS", "FAILED"
  gatewayTransactionId String?
  createdAt            DateTime  @default(now())

  user                 User      @relation(fields: [userId], references: [id])
}

model Class {
  id          String    @id @default(uuid())
  programId   String
  teacherId   String
  name        String    // e.g., "HSK2 - Lớp tối T3T5"
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  program     Program           @relation(fields: [programId], references: [id])
  teacher     User              @relation("TeacherClasses", fields: [teacherId], references: [id])
  enrollments ClassEnrollment[]
  assignments Assignment[]
}

model ClassEnrollment {
  id        String   @id @default(uuid())
  classId   String
  studentId String
  joinedAt  DateTime @default(now())

  class     Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User  @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
}

model Assignment {
  id        String    @id @default(uuid())
  classId   String
  lessonId  String
  dueDate   DateTime?
  note      String?
  createdAt DateTime  @default(now())

  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([classId, lessonId])
}
