          {
            "speaker": "病人",
            "zh": "医生，我头疼，感觉有点儿发烧。",
            "py": "Yīshēng, wǒ tóuténg, gǎnjué yǒudiǎnr fāshāo.",
            "vi": "Bác sĩ, tôi bị đau đầu, cảm thấy hơi sốt."
          },
          {
            "speaker": "医生",
            "zh": "你生病了，是感冒。你得吃药。",
            "py": "Nǐ shēngbìng le, shì gǎnmào. Nǐ děi chī yào.",
            "vi": "Bạn bị ốm rồi, là cảm cúm. Bạn phải uống thuốc."
          },
          {
            "speaker": "病人",
            "zh": "好，谢谢医生。",
            "py": "Hǎo, xièxie yīshēng.",
            "vi": "Vâng, cảm ơn bác sĩ."
          },
          {
            "speaker": "医生",
            "zh": "你应该多喝水，多休息。",
            "py": "Nǐ yīnggāi duō hē shuǐ, duō xiūxi.",
            "vi": "Bạn nên uống nhiều nước, nghỉ ngơi nhiều hơn."
          }
        ]
      }
